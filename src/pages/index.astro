---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ProgressBar from '../components/ProgressBar.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Hero from '../components/Hero.astro';
import TrustSignals from '../components/TrustSignals.astro';
import Services from '../components/Services.astro';
import Why from '../components/Why.astro';
import Testimonials from '../components/Testimonials.astro';
import Tech from '../components/Tech.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<Layout title="TecnoDespegue | Desarrollo Fullstack & Automatizaciones con IA">
  <ProgressBar />
  <CustomCursor />
  <Nav />
  
  <main>
    <Hero />
    
    <ScrollReveal>
      <TrustSignals />
    </ScrollReveal>
    
    <ScrollReveal delay={100}>
      <Services />
    </ScrollReveal>
    
    <ScrollReveal delay={200}>
      <Why />
    </ScrollReveal>
    
    <ScrollReveal delay={100}>
      <Testimonials />
    </ScrollReveal>
    
    <ScrollReveal delay={100}>
      <Tech />
    </ScrollReveal>
    
    <ScrollReveal delay={200}>
      <CTA />
    </ScrollReveal>
  </main>
  
  <Footer />
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
