---
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-30"></div>
  <div class="absolute inset-0 hero-gradient"></div>
  
  <div class="max-w-7xl mx-auto px-8 relative z-10 grid lg:grid-cols-2 gap-12 items-center">
    <div class="space-y-8">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-sm bg-surface-container border border-primary/20">
        <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
        <span class="text-[0.6875rem] font-label text-primary uppercase tracking-widest">
          IA-READY SOLUTIONS
        </span>
      </div>
      
      <h1 class="font-headline text-[3.5rem] md:text-[4.5rem] leading-[1.05] tracking-tight font-bold text-on-surface">
        Automatizamos tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">futuro digital</span>
      </h1>
      
      <p class="text-on-surface-variant text-lg max-w-lg font-body leading-relaxed">
        Desarrollo fullstack, automatizaciones con IA y flujos de trabajo inteligentes para empresas que buscan escalar sin límites.
      </p>
      
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="#contacto" class="btn-primary">
          Iniciar Proyecto
        </a>
        <a href="#soluciones" class="btn-secondary">
          Nuestros Servicios
        </a>
      </div>
    </div>
    
    <div class="relative hidden lg:block">
      <div class="aspect-square relative">
        <!-- Animated gradient glow -->
        <div class="absolute inset-0 bg-primary/10 blur-[100px] rounded-full animate-pulse-slow"></div>
        
        <!-- 3D-style geometric visualization -->
        <div class="w-full h-full relative rounded-xl border border-white/10 bg-gradient-to-br from-surface-container-low to-black overflow-hidden">
          <!-- Grid overlay -->
          <div class="absolute inset-0 grid-bg opacity-20"></div>
          
          <!-- Floating geometric shapes -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative w-64 h-64">
              <!-- Main sphere -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-40 h-40 rounded-full bg-gradient-to-br from-primary/20 to-secondary/10 border border-primary/30 animate-float"></div>
              
              <!-- Orbiting rings -->
              <div class="absolute inset-0 border border-primary/20 rounded-full animate-spin-slow"></div>
              <div class="absolute inset-4 border border-secondary/20 rounded-full animate-spin-reverse"></div>
              
              <!-- Corner accents -->
              <div class="absolute top-0 right-0 w-16 h-16 border-t-2 border-r-2 border-primary/40"></div>
              <div class="absolute bottom-0 left-0 w-16 h-16 border-b-2 border-l-2 border-secondary/40"></div>
            </div>
          </div>
          
          <!-- Scan line effect -->
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/5 to-transparent h-32 animate-scan"></div>
        </div>
        
        <!-- Floating badge with icon -->
        <div class="absolute -bottom-6 -left-6 bg-surface-container p-6 border border-white/5 shadow-2xl rounded-md max-w-xs glass-effect hover:scale-105 transition-transform">
          <span class="material-symbols-outlined text-secondary text-4xl mb-4 block">terminal</span>
          <p class="text-sm font-label text-on-surface-variant leading-snug italic">
            "Transformamos ideas complejas en código de alto rendimiento."
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
