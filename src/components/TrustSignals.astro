---
const stats = [
  { value: "50+", label: "Proyectos Entregados" },
  { value: "99.9%", label: "Uptime Promedio" },
  { value: "<24h", label: "Tiempo de Respuesta" },
  { value: "15+", label: "Tecnologías Dominadas" }
];
---

<section class="py-16 bg-surface border-y border-white/5">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((stat) => (
        <div class="group">
          <div class="text-4xl md:text-5xl font-headline font-bold text-primary mb-2 group-hover:scale-110 transition-transform">
            {stat.value}
          </div>
          <div class="text-xs text-on-surface-variant uppercase tracking-widest">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Trust badge -->
    <div class="mt-12 flex flex-wrap justify-center gap-6 items-center opacity-50">
      <div class="flex items-center gap-2 text-on-surface-variant text-xs">
        <span class="material-symbols-outlined text-lg">verified_user</span>
        <span>ISO 27001 Compliant</span>
      </div>
      <div class="flex items-center gap-2 text-on-surface-variant text-xs">
        <span class="material-symbols-outlined text-lg">security</span>
        <span>GDPR Ready</span>
      </div>
      <div class="flex items-center gap-2 text-on-surface-variant text-xs">
        <span class="material-symbols-outlined text-lg">workspace_premium</span>
        <span>Enterprise Grade</span>
      </div>
    </div>
  </div>
</section>
