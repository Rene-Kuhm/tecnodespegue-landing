---
import ContactForm from './ContactForm.astro';
---

<section class="py-32 relative" id="contacto">
  <div class="absolute inset-0 grid-bg opacity-10"></div>
  
  <div class="max-w-6xl mx-auto px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="font-headline text-[3rem] md:text-[4rem] font-bold tracking-tighter mb-6 leading-tight">
        ¿Listo para <span class="italic underline decoration-primary decoration-4 underline-offset-8">despegar</span>?
      </h2>
      
      <p class="text-on-surface-variant text-xl mb-8">
        Agenda una consulta técnica de 30 minutos o escribinos directamente.
      </p>
      
      <!-- Quick actions -->
      <div class="flex flex-wrap gap-4 justify-center mb-12">
        <a 
          href="#form"
          class="group relative inline-flex items-center justify-center btn-primary"
        >
          <span class="relative z-10 flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">calendar_month</span>
            Agendar Consulta Gratis
          </span>
        </a>
        
        <a 
          href="https://wa.me/5491112345678?text=Hola,%20quiero%20consultar%20sobre%20un%20proyecto"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-sm">chat</span>
          WhatsApp Directo
        </a>
      </div>
    </div>
    
    <!-- Contact Form -->
    <div id="form">
      <ContactForm />
    </div>
    
    <!-- Trust signals footer -->
    <div class="mt-20 pt-20 border-t border-white/5 flex flex-wrap justify-center gap-12 text-zinc-600">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">verified</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">Respuesta &lt; 24h</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">code</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">Consulta Sin Costo</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">support_agent</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">NDA Disponible</span>
      </div>
    </div>
  </div>
</section>
