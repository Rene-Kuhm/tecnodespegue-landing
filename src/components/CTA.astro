---
---

<section class="py-32 relative" id="contacto">
  <div class="absolute inset-0 grid-bg opacity-10"></div>
  
  <div class="max-w-4xl mx-auto px-8 relative z-10 text-center">
    <h2 class="font-headline text-[3rem] md:text-[4rem] font-bold tracking-tighter mb-6 leading-tight">
      ¿Listo para <span class="italic underline decoration-primary decoration-4 underline-offset-8">despegar</span>?
    </h2>
    
    <p class="text-on-surface-variant text-xl mb-12">
      Contanos tu proyecto y veamos cómo podemos ayudarte a transformar tu visión técnica en realidad.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a 
        href="mailto:contacto@tecnodespegue.com"
        class="group relative inline-flex items-center justify-center btn-primary"
      >
        <span class="relative z-10">Enviar Email</span>
        <div class="absolute inset-0 bg-gradient-to-r from-primary to-primary-dim opacity-0 group-hover:opacity-100 transition-opacity rounded-md"></div>
      </a>
      
      <a 
        href="https://wa.me/5491112345678"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        WhatsApp
      </a>
    </div>
    
    <div class="mt-20 pt-20 border-t border-white/5 flex flex-wrap justify-center gap-12 text-zinc-600">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">verified</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">Global Delivery</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">code</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">Custom Architecture</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">support_agent</span>
        <span class="text-[10px] uppercase font-bold tracking-widest">24/7 Monitoring</span>
      </div>
    </div>
  </div>
</section>
